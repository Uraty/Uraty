# 1) デフォルト: テキストは自動判定 + LFへ統一
* text=auto eol=lf

# 2) Git hooksは必ずLF（hookがCRLFだと壊れる）
.githooks/* text eol=lf

# -----------------------------
# C# / .NET / Unity scripts
# -----------------------------
*.cs         text eol=lf
*.csproj     text eol=lf
*.sln        text eol=lf
*.props      text eol=lf
*.targets    text eol=lf
*.editorconfig text eol=lf

# -----------------------------
# Unity YAML系
# -----------------------------
*.meta       text eol=lf
*.unity      text eol=lf
*.prefab     text eol=lf
*.asset      text eol=lf
*.mat        text eol=lf
*.anim       text eol=lf
*.controller text eol=lf
*.overrideController text eol=lf
*.playable   text eol=lf
*.mask       text eol=lf
*.guiskin    text eol=lf
