#!/usr/bin/env bash
set -euo pipefail
export LC_ALL=C

# Bash 4+ 必須（declare -A のため）
if (( BASH_VERSINFO[0] < 4 )); then
  echo "[ERROR] Bash 4+ が必要です（現在: ${BASH_VERSION}）"
  echo "        macOS 標準 /bin/bash (3.2) では動作しません。brew の bash 等を使用してください。"
  exit 1
fi

echo "=== Pre-commit (Unity) ==="

# しきい値
readonly WARN_SIZE=$((50 * 1024 * 1024))      # 50MB 警告
readonly ERROR_SIZE=$((100 * 1024 * 1024))    # 100MB エラー

# -----------------------------
# A) protected branch 直コミット禁止（ローカルルール）
#    ※ CI と完全一致させる対象ではないが、ローカル抑止として残す
# -----------------------------
BRANCH="$(git rev-parse --abbrev-ref HEAD 2>/dev/null || echo "")"
case "$BRANCH" in
  main)
    echo "[ERROR] $BRANCH への直接コミットは禁止です（ブランチを切ってPRしてください）"
    exit 1
    ;;
esac

# -----------------------------
# 共通関数
# -----------------------------

# git check-attr が --cached をサポートしていれば index 上の .gitattributes を参照
declare -a GIT_CHECK_ATTR_BASE_ARGS=()
if grep -q -- '--cached' < <(git check-attr -h 2>&1); then
  GIT_CHECK_ATTR_BASE_ARGS=(--cached)
fi

# git attribute の値を取得
# 返り値例: set / unset / unspecified / auto / lf / crlf
git_attr_value() {
  local p="$1"
  local attr="$2"
  local _path _attr _val

  while IFS= read -r -d '' _path \
    && IFS= read -r -d '' _attr \
    && IFS= read -r -d '' _val; do
    if [[ "$_attr" == "$attr" ]]; then
      printf '%s\n' "$_val"
      return 0
    fi
  done < <(git check-attr "${GIT_CHECK_ATTR_BASE_ARGS[@]}" -z "$attr" -- "$p" 2>/dev/null || true)

  printf 'unspecified\n'
}

is_forbidden_path() {
  local p="$1"
  case "$p" in
    Library/*|Temp/*|Logs/*|obj/*|UserSettings/*)
      return 0
      ;;
    *)
      return 1
      ;;
  esac
}

# index にエントリが存在するか
index_has_entry() {
  local p="$1"
  git cat-file -e ":$p" 2>/dev/null
}

# index 上のエントリ型を返す（blob / tree / commit / ...）
index_entry_type() {
  local p="$1"
  git cat-file -t ":$p" 2>/dev/null || true
}

# index に追跡された子孫があるか
# -> 空フォルダは Git 上の実体とみなさない
index_has_tracked_descendant() {
  local dir="$1"
  git ls-files --cached -- "$dir/" | grep -q .
}

# index 上で「本体ファイル」または「非空ディレクトリ」があるか
index_has_file_or_nonempty_dir() {
  local p="$1"

  if index_has_entry "$p"; then
    return 0
  fi

  index_has_tracked_descendant "$p"
}

# index 上の blob が「たぶんテキスト」かをざっくり判定
# - エントリ未存在 / non-blob は対象外
# - 空ファイルはテキスト扱い
# - grep -I でバイナリっぽいものを除外
staged_blob_is_probably_text() {
  local p="$1"
  local size

  if ! index_has_entry "$p"; then
    return 1
  fi

  if [[ "$(index_entry_type "$p")" != "blob" ]]; then
    return 1
  fi

  size="$(git cat-file -s ":$p" 2>/dev/null || echo 0)"
  if (( size == 0 )); then
    return 0
  fi

  grep -Iq '' < <(git cat-file -p ":$p" 2>/dev/null)
}

# conflict marker チェック対象か（.gitattributes ベース）
is_text_like() {
  local p="$1"
  local text_attr
  local eol_attr

  text_attr="$(git_attr_value "$p" text)"
  eol_attr="$(git_attr_value "$p" eol)"

  # 明示的 binary / -text は対象外
  if [[ "$text_attr" == "unset" ]]; then
    return 1
  fi

  # eol 指定ありなら text 前提
  # text=set/auto も対象候補
  case "$eol_attr" in
    lf|crlf) ;;
    *)
      case "$text_attr" in
        set|auto) ;;
        *) return 1 ;;
      esac
      ;;
  esac

  staged_blob_is_probably_text "$p"
}

# .gitattributes の eol=lf を正として LF 強制対象か
should_enforce_lf() {
  local p="$1"
  local eol_attr

  eol_attr="$(git_attr_value "$p" eol)"
  [[ "$eol_attr" == "lf" ]] || return 1

  staged_blob_is_probably_text "$p"
}

# .gitattributes で text/eol のどちらかが明示されているか
has_explicit_text_or_eol_attr() {
  local p="$1"
  local text_attr
  local eol_attr

  text_attr="$(git_attr_value "$p" text)"
  eol_attr="$(git_attr_value "$p" eol)"

  [[ "$text_attr" != "unspecified" || "$eol_attr" != "unspecified" ]]
}

# Assets配下のパスについて、親フォルダの .meta が index に存在するか確認
# 例:
#   Assets/Foo/Bar.cs      -> Assets/Foo.meta が必要
#   Assets/Foo/Bar/Baz.cs  -> Assets/Foo/Bar.meta, Assets/Foo.meta が必要
#   Assets/Foo.meta        -> 親が Assets のみなら追加チェックなし
check_assets_parent_dir_metas() {
  local p="$1"
  local base dir parent

  case "$p" in
    Assets/*) ;;
    *) return 0 ;;
  esac

  if [[ "$p" == *.meta ]]; then
    base="${p%.meta}"
  else
    base="$p"
  fi

  if [[ "$base" != */* ]]; then
    return 0
  fi

  dir="${base%/*}"

  # Assets 自体の .meta は要求しない
  while [[ "$dir" == Assets/* ]]; do
    if ! index_has_entry "$dir.meta"; then
      echo "[ERROR] 親フォルダの .meta が不足しています（ステージされていません）: $dir.meta"
      exit 1
    fi
    parent="${dir%/*}"
    [[ "$parent" == "$dir" ]] && break
    dir="$parent"
  done
}

# -----------------------------
# 変更一覧の収集（NUL区切りで安全にパース）
#   - deleted         : ステージ上で削除されたパス
#   - changed_or_added: ステージ上で追加/変更/rename先/copy先/typechange のパス
#   - touched_non_deleted: ステージ上で削除以外に触れたパス
# -----------------------------
declare -A deleted=()
declare -A changed_or_added=()
declare -A touched_non_deleted=()

while IFS= read -r -d '' status; do
  case "$status" in
    R*)
      IFS= read -r -d '' oldpath
      IFS= read -r -d '' newpath

      # rename 先だけ禁止判定（削除側は許可）
      if is_forbidden_path "$newpath"; then
        echo "[ERROR] 禁止ディレクトリがステージされています: $newpath"
        exit 1
      fi

      deleted["$oldpath"]=1
      changed_or_added["$newpath"]=1
      touched_non_deleted["$newpath"]=1
      ;;

    C*)
      IFS= read -r -d '' oldpath
      IFS= read -r -d '' newpath

      if is_forbidden_path "$newpath"; then
        echo "[ERROR] 禁止ディレクトリがステージされています: $newpath"
        exit 1
      fi

      changed_or_added["$newpath"]=1
      touched_non_deleted["$newpath"]=1
      ;;

    *)
      IFS= read -r -d '' path

      case "$status" in
        D)
          # 削除は許可（禁止ディレクトリ掃除を止めない）
          deleted["$path"]=1
          ;;

        A|M|T)
          if is_forbidden_path "$path"; then
            echo "[ERROR] 禁止ディレクトリがステージされています: $path"
            exit 1
          fi
          changed_or_added["$path"]=1
          touched_non_deleted["$path"]=1
          ;;

        U|AA|AU|UA|DD|DU|UD|UU)
          echo "[ERROR] unmerged 状態のファイルがあります: $path (status=$status)"
          exit 1
          ;;

        *)
          echo "[ERROR] 未対応ステータスを検出しました: status='$status' path='$path'"
          echo "        このフックは fail-closed 設計です。ステータス対応を追加してください。"
          exit 1
          ;;
      esac
      ;;
  esac
done < <(git diff --cached --find-renames --find-copies --name-status -z)

# 念のため二重防御：unmerged index エントリが残っていたら即エラー
if git ls-files -u --error-unmatch -- ':/' >/dev/null 2>&1; then
  echo "[ERROR] unmerged 状態の index エントリが残っています（競合を解消してからコミットしてください）"
  exit 1
fi

# -----------------------------
# B) マージコンフリクト残骸検出
#     - ステージ済み blob を見る
#     - ======= 単体は無視
# -----------------------------
for p in "${!touched_non_deleted[@]}"; do
  if ! is_text_like "$p"; then
    continue
  fi

  has_conflict_start=0
  has_conflict_end=0

  if grep -aqE '^<<<<<<< ' < <(git cat-file -p ":$p" 2>/dev/null); then
    has_conflict_start=1
  fi
  if grep -aqE '^>>>>>>> ' < <(git cat-file -p ":$p" 2>/dev/null); then
    has_conflict_end=1
  fi

  if (( has_conflict_start && has_conflict_end )); then
    echo "[ERROR] マージコンフリクト残骸が含まれています（開始/終了マーカー両方を検出）: $p"
    exit 1
  fi

  if (( has_conflict_start || has_conflict_end )); then
    echo "[ERROR] 壊れたマージコンフリクト残骸の可能性があります（片側マーカーのみ検出）: $p"
    echo "        conflict markers: start=$has_conflict_start end=$has_conflict_end"
    exit 1
  fi
done

# -----------------------------
# C) .gitattributes 未指定のテキストっぽいファイル検出
# -----------------------------
for p in "${!touched_non_deleted[@]}"; do
  if has_explicit_text_or_eol_attr "$p"; then
    continue
  fi

  if staged_blob_is_probably_text "$p"; then
    echo "[ERROR] .gitattributes 未指定のテキストっぽいファイルがステージされています: $p"
    echo "        .gitattributes に text/eol（例: text eol=lf）または -text を明示してください。"
    echo "        check-attr: text=$(git_attr_value "$p" text), eol=$(git_attr_value "$p" eol)"
    exit 1
  fi
done

# -----------------------------
# D) Unity .meta 整合
#     - 空フォルダは本体として認めない
#     - 本体ファイル or 非空ディレクトリ（追跡子孫あり）のみ有効
# -----------------------------

# 追加/変更/rename/copy された Assets配下(非 .meta)は .meta が index に存在すること
for p in "${!changed_or_added[@]}"; do
  case "$p" in
    Assets/*)
      case "$p" in
        *.meta)
          : ;;
        *)
          if ! index_has_entry "$p.meta"; then
            echo "[ERROR] .meta が不足しています（ステージされていません）: $p.meta"
            exit 1
          fi
          ;;
      esac

      check_assets_parent_dir_metas "$p"
      ;;
  esac
done

# .meta だけ追加/変更/rename されていないか
# -> 空ディレクトリは NG
for p in "${!changed_or_added[@]}"; do
  case "$p" in
    Assets/*.meta)
      base="${p%.meta}"

      if index_has_file_or_nonempty_dir "$base"; then
        :
      else
        echo "[ERROR] .meta だけが追加/変更されています（本体ファイルまたは非空フォルダが見つかりません）: $p"
        echo "        空フォルダは Git 上の実体として扱いません。必要なら .gitkeep 等を追加してください。"
        exit 1
      fi
      ;;
  esac
done

# 削除された Assets配下(非 .meta)は .meta も削除されていること
for p in "${!deleted[@]}"; do
  case "$p" in
    Assets/*)
      case "$p" in
        *.meta)
          : ;;
        *)
          if index_has_entry "$p.meta"; then
            echo "[ERROR] 本体を削除していますが .meta が削除されていません: $p.meta"
            exit 1
          fi
          ;;
      esac
      ;;
  esac
done

# .meta だけ削除されていないか
# -> index 上に本体ファイル or 非空ディレクトリが残っていれば NG
for p in "${!deleted[@]}"; do
  case "$p" in
    Assets/*.meta)
      base="${p%.meta}"

      if index_has_file_or_nonempty_dir "$base"; then
        echo "[ERROR] .meta だけ削除されています（本体ファイルまたは非空フォルダが残っています）: $p"
        exit 1
      fi
      ;;
  esac
done

# -----------------------------
# E) 巨大ファイル検出
#     - non-blob は対象外
# -----------------------------
for p in "${!touched_non_deleted[@]}"; do
  local_type="$(index_entry_type "$p")"
  if [[ "$local_type" != "blob" ]]; then
    continue
  fi

  size="$(git cat-file -s ":$p" 2>/dev/null || echo 0)"

  if (( size > ERROR_SIZE )); then
    echo "[ERROR] 100MB超のファイルがステージされています: $p (${size} bytes)"
    echo "        Git LFS等を検討してください。"
    exit 1
  elif (( size > WARN_SIZE )); then
    echo "[WARNING] 50MB超のファイル: $p (${size} bytes)  ※GitHub推奨上限超え"
  fi
done

# -----------------------------
# F) CRLF チェック
#     - .gitattributes の eol=lf を正とする
# -----------------------------
for p in "${!touched_non_deleted[@]}"; do
  if ! should_enforce_lf "$p"; then
    continue
  fi

  if grep -aq $'\r' < <(git cat-file -p ":$p" 2>/dev/null); then
    echo "[ERROR] CRLF(\\r\\n) が含まれています（.gitattributes では LF 指定）: $p"
    exit 1
  fi
done

# -----------------------------
# G) Unity EditorSettings 強制（Force Text）
# -----------------------------
check_unity_editor_settings() {
  local p="ProjectSettings/EditorSettings.asset"

  # Unityプロジェクトでない / 未追跡ならスキップ
  if ! index_has_entry "$p"; then
    return 0
  fi

  if [[ "$(index_entry_type "$p")" != "blob" ]]; then
    echo "[ERROR] ProjectSettings/EditorSettings.asset が通常ファイルではありません: $p"
    exit 1
  fi

  if ! grep -qE '^  m_SerializationMode: 2$' < <(git cat-file -p ":$p" 2>/dev/null); then
    echo "[ERROR] Unity Asset Serialization Mode が Force Text ではありません: $p"
    echo "        Edit > Project Settings > Editor > Asset Serialization > Mode = Force Text"
    exit 1
  fi
}

check_unity_editor_settings

echo "[OK] Pre-commit passed"
exit 0