#!/bin/sh
#
# prepare-commit-msg
# Template helper (not enforcement):
# - Prefill "type(scope): " skeleton (type/scope are TODO)
# - Show candidate types and scope hints
# - Extract Issue id from branch name: <any>/<digits>-<desc>  -> Issue: <digits>
#
# Notes:
# - Do not overwrite an existing non-comment message (GUI often uses -F temp file)
#

COMMIT_MSG_FILE=$1
COMMIT_SOURCE=$2

# Skip for merges/squashes (do not touch generated messages)
case "$COMMIT_SOURCE" in
  merge|squash) exit 0 ;;
esac

# If there is already a real (non-comment, non-empty) line, do nothing.
if grep -qE '^[[:space:]]*[^#[:space:]]' "$COMMIT_MSG_FILE"; then
  exit 0
fi

BRANCH=$(git symbolic-ref --quiet --short HEAD 2>/dev/null)

# Try to extract ticket id from branch: .../<digits>-...
TICKET=""
if [ -n "$BRANCH" ]; then
  REST=$(printf "%s" "$BRANCH" | awk -F/ '{print $2}')
  TICKET=$(printf "%s" "$REST" | sed -n 's/^\([0-9][0-9]*\)-.*/\1/p')
fi

if [ -n "$TICKET" ]; then
  ISSUE_LINE="Issue: $TICKET"
else
  ISSUE_LINE="Issue: <id>"
fi

# Suggest scope from branch description (after ticket id), first token
SUG_SCOPE=""
if [ -n "$BRANCH" ]; then
  REST=$(printf "%s" "$BRANCH" | awk -F/ '{print $2}')
  DESC=$(printf "%s" "$REST" | sed 's/^[0-9][0-9]*-//')
  SUG_SCOPE=$(printf "%s" "$DESC" | awk -F- '{print $1}')
  printf "%s" "$SUG_SCOPE" | grep -Eq '^[a-z0-9_-]+$' || SUG_SCOPE=""
fi

cat > "$COMMIT_MSG_FILE" <<EOF
type(scope): summary

$ISSUE_LINE

WHY:
WHAT:

# Types: feat | fix | refactor | chore | docs | test | ci
# Format: <type>(<scope>): <summary>  OR  <type>: <summary>
# Examples:
#   feat(player): add jump
#   fix(player): prevent null ref
#   chore(hooks): enforce conventional commits
EOF

# If we have a suggested scope, add it as a hint (comment)
if [ -n "$SUG_SCOPE" ]; then
  printf "%s\n" "# Suggested scope: $SUG_SCOPE" >> "$COMMIT_MSG_FILE"
else
  printf "%s\n" "# Suggested scope: <scope>" >> "$COMMIT_MSG_FILE"
fi

exit 0