#!/bin/sh

COMMIT_MSG_FILE=$1
SUBJECT=$(head -n 1 "$COMMIT_MSG_FILE")

# 件名が空
if [ -z "$SUBJECT" ]; then
  echo "Error: 件名が空です。" >&2
  exit 1
fi

# type形式チェック
echo "$SUBJECT" | grep -Eq '^(feature|fix|refactor|chore|docs|test|ci)(\([a-z0-9_-]+\))?: .+'
if [ $? -ne 0 ]; then
  echo "Error: 形式が不正です。" >&2
  echo "Use: <type>(scope): summary" >&2
  exit 1
fi

# 長さチェック
LENGTH=$(printf "%s" "$SUBJECT" | wc -m | tr -d ' ')
if [ "$LENGTH" -gt 50 ]; then
  echo "Error: 件名は 50 文字以内にしてください。" >&2
  exit 1
fi

# Reason 空チェック（Reason: 行があるなら、理由を書くか行を削除）
awk '
BEGIN { in_reason=0; bad=0 }
{
  if ($0 ~ /^Reason:[[:space:]]*$/) { in_reason=1; next }
  if (in_reason==1) {
    if ($0 ~ /^#/) next
    if ($0 ~ /^[[:space:]]*$/) next
    in_reason=0
  }
}
END {
  if (in_reason==1) bad=1
  exit bad
}
' "$COMMIT_MSG_FILE"

if [ $? -ne 0 ]; then
  echo "Error: Reason が空です。理由を書くか、Reason 行を削除してください。" >&2
  exit 1
fi

# Issue 空チェック（Issue: 行があるなら、番号を書くか行を削除）
# 例: "Issue:" や "Issue:   " をエラーにする
if grep -Eq '^[[:space:]]*Issue:[[:space:]]*$' "$COMMIT_MSG_FILE"; then
  echo "Error: Issue が空です。Issue に番号を入力するか、Issue 行を削除してください。" >&2
  exit 1
fi

# Issue 警告のみ（feature / fix / refactor で Issue 参照が無いと警告）
# コメント行(# ...)は判定対象から外す
HAS_ISSUE=0
grep -Ev '^[[:space:]]*#' "$COMMIT_MSG_FILE" | \
  grep -Eiq 'Issue:?[[:space:]]*#?[0-9]+|Closes[[:space:]]+#?[0-9]+|Refs[[:space:]]+#?[0-9]+|#[0-9]+' \
  && HAS_ISSUE=1

printf "%s" "$SUBJECT" | grep -Eq '^(feature|fix|refactor)'
if [ $? -eq 0 ] && [ "$HAS_ISSUE" -ne 1 ]; then
  echo "Warning: feature / fix / refactor では Issue 参照を推奨します（Issue: 123 など）。" >&2
fi

exit 0