# この .editorconfig をリポジトリのルート設定として扱う（上位フォルダを探索しない）
root = true

[*]
# 文字コードを UTF-8 に統一する（BOM 有無はエディタ依存のため utf-8 指定に留める）
charset = utf-8
# 改行コードを LF に統一する（Windows 環境でも差分汚れを減らす）
end_of_line = lf
# ファイル末尾に改行を必ず入れる（POSIX系ツールとの相性・差分安定化）
insert_final_newline = true
# 行末の不要な空白を削除する（差分ノイズ防止）
trim_trailing_whitespace = true
# 基本インデントはスペースを使う（タブ混在を防ぐ）
indent_style = space
# 基本インデント幅は 2（Markdown/YAML/設定ファイル向けの共通デフォルト）
indent_size = 2

[*.md]
# Markdown は行末スペースに意味がある場合があるため、末尾空白の自動削除を無効化する
trim_trailing_whitespace = false

[*.yml]
# YAML はスペースインデントを前提とするため、明示してブレを防ぐ
indent_style = space
# YAML の一般的なインデント幅として 2 を使う
indent_size = 2

[*.yaml]
# YAML はスペースインデントを前提とするため、明示してブレを防ぐ
indent_style = space
# YAML の一般的なインデント幅として 2 を使う
indent_size = 2

[*.json]
# JSON はスペースインデントを使う（チーム内での保存差分を減らす）
indent_style = space
# JSON のインデント幅を 2 に統一する
indent_size = 2

# ------------------------------
# Unity の YAML 系アセット（任意だが入れておくと安定）
# ------------------------------

[*.meta]
# Unity .meta は YAML ベースなのでスペースインデントを明示する
indent_style = space
# Unity YAML 系の見やすさを優先して 2 スペースにする
indent_size = 2

[*.unity]
# Unity シーンファイルは YAML ベースなのでスペースインデントを明示する
indent_style = space
# Unity シーンファイルのインデント幅を 2 に統一する
indent_size = 2

[*.prefab]
# Unity Prefab は YAML ベースなのでスペースインデントを明示する
indent_style = space
# Unity Prefab のインデント幅を 2 に統一する
indent_size = 2

[*.asset]
# Unity .asset は YAML ベースのものが多いためスペースインデントを明示する
indent_style = space
# Unity .asset のインデント幅を 2 に統一する
indent_size = 2

# ------------------------------
# C#（Unity 本体）
# ------------------------------

[*.cs]
# C# はスペースインデントを使う（Unity/VS/Rider の共通運用に合わせる）
indent_style = space
# C# のインデント幅は 4 に統一する（一般的な C# 慣習）
indent_size = 4
# タブ幅も 4 とみなす（表示揺れ防止）
tab_width = 4
# .NET の Style カテゴリ診断の既定重大度を warning にする（まずは強すぎない運用）
dotnet_analyzer_diagnostic.category-Style.severity = warning
# .NET の Naming カテゴリ診断の既定重大度を warning にする（命名規約の可視化）
dotnet_analyzer_diagnostic.category-Naming.severity = warning
# using の並びで System.* を先頭グループに寄せる（並び順の差分を減らす）
dotnet_sort_system_directives_first = true
# using グループ間を空行で分ける（可読性向上）
dotnet_separate_import_directive_groups = true
# using を namespace の外側に配置する（ファイル全体で一貫させる）
csharp_using_directive_placement = outside_namespace
# 非 interface メンバーにはアクセス修飾子を明示する（可視性を曖昧にしない）
dotnet_style_require_accessibility_modifiers = for_non_interface_members:warning
# フィールド参照で this. を原則不要にする（冗長さを減らす）
dotnet_style_qualification_for_field = false:suggestion
# プロパティ参照で this. を原則不要にする（冗長さを減らす）
dotnet_style_qualification_for_property = false:suggestion
# メソッド呼び出しで this. を原則不要にする（冗長さを減らす）
dotnet_style_qualification_for_method = false:suggestion
# イベント参照で this. を原則不要にする（冗長さを減らす）
dotnet_style_qualification_for_event = false:suggestion
# 組み込み型（int/string 等）は C# のキーワード表記を優先する（int, string を使う）
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
# 組み込み型（int/string 等）はメンバーアクセスでも C# キーワード表記を優先する
dotnet_style_predefined_type_for_member_access = true:suggestion
# 波括弧は常に付ける（単一文 if 等の事故を防ぐ）
csharp_prefer_braces = true:warning
# 開き波括弧の改行位置をすべての構文で統一する（読みやすさと差分安定）
csharp_new_line_before_open_brace = all
# else の前に改行を入れる（K&R混在防止）
csharp_new_line_before_else = true
# catch の前に改行を入れる（K&R混在防止）
csharp_new_line_before_catch = true
# finally の前に改行を入れる（K&R混在防止）
csharp_new_line_before_finally = true
# オブジェクト初期化子の各メンバーを改行して配置する（差分が見やすい）
csharp_new_line_before_members_in_object_initializers = true
# 匿名型の各メンバーを改行して配置する（差分が見やすい）
csharp_new_line_before_members_in_anonymous_types = true
# switch の case 内の内容をインデントする（ネストの視認性向上）
csharp_indent_case_contents = true
# switch の case ラベルをインデントする（可読性向上）
csharp_indent_switch_labels = true
# ラベル（goto先など）は一段浅く配置する（一般的な C# スタイル）
csharp_indent_labels = one_less_than_current
# 1行ブロックの温存は原則しない（記法の揺れを減らす）
csharp_preserve_single_line_blocks = false
# 1行文の温存は原則しない（if/for などの記法を統一する）
csharp_preserve_single_line_statements = false
# 組み込み型で var を使うか（int x = 0; を優先。チームで揉めやすいので suggestion）
csharp_style_var_for_built_in_types = false:suggestion
# 右辺から型が明白なときは var を許容する（new Foo() 等）
csharp_style_var_when_type_is_apparent = true:suggestion
# それ以外は var を原則使わない（型の明示を優先）
csharp_style_var_elsewhere = false:suggestion
# 読み取り専用で1行に収まる場合のみ、プロパティ全体の => を許容する
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
# get/set のアクセサ単位の => は原則使わない（ブロックを優先）
csharp_style_expression_bodied_accessors = false:suggestion
# null 伝播演算子 (?.) を使える場面では使うことを推奨（簡潔・安全）
dotnet_style_null_propagation = true:suggestion
# null 合体演算子 (?? / ??=) を使える場面では使うことを推奨（簡潔）
dotnet_style_coalesce_expression = true:suggestion
# object.ReferenceEquals などより is null / is not null を推奨（可読性）
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion
# 可能な場合は auto property を推奨（単純な backing field を減らす）
dotnet_style_prefer_auto_properties = true:suggestion
# コレクション初期化子を使える場面では使うことを推奨（簡潔）
dotnet_style_collection_initializer = true:suggestion
# object 初期化子を使える場面では使うことを推奨（代入漏れが見えやすい）
dotnet_style_object_initializer = true:suggestion
# 未使用 using（IDE0005）を warning にする（不要 import の蓄積防止）
dotnet_diagnostic.IDE0005.severity = warning
# 型/メンバー名とファイルスコープ外のルールに関する診断の一部を warning にする（IDE 依存差をならす）
dotnet_diagnostic.IDE1006.severity = warning

# ------------------------------
# C# 命名規則（あなたの conventions と整合する部分）
# ------------------------------

# ---- 命名スタイル定義 ----

# PascalCase（型名/メソッド/プロパティ/イベントなどに使用）
dotnet_naming_style.pascal_case.capitalization = pascal_case
# camelCase（引数/ローカル変数に使用）
dotnet_naming_style.camel_case.capitalization = camel_case
# インターフェースは I + PascalCase（例: IDamageable）
dotnet_naming_style.interface_prefix_i.required_prefix = I
# インターフェース名本体の大文字規則は PascalCase
dotnet_naming_style.interface_prefix_i.capitalization = pascal_case
# private フィールドは _ + camelCase（例: _currentHp）
dotnet_naming_style.private_field_underscore.required_prefix = _
# private フィールド名本体の大文字規則は camelCase
dotnet_naming_style.private_field_underscore.capitalization = camel_case

# ---- 対象シンボル定義 ----

# インターフェース型を命名規則の対象にする
dotnet_naming_symbols.interfaces.applicable_kinds = interface
# インターフェースはアクセス修飾子を問わず対象にする
dotnet_naming_symbols.interfaces.applicable_accessibilities = *
# class / struct / enum を型名ルールの対象にする
dotnet_naming_symbols.types.applicable_kinds = class, struct, enum
# 型名はアクセス修飾子を問わず対象にする
dotnet_naming_symbols.types.applicable_accessibilities = *
# メソッド / プロパティ / イベントを PascalCase ルールの対象にする
dotnet_naming_symbols.methods_properties_events.applicable_kinds = method, property, event
# メソッド / プロパティ / イベントはアクセス修飾子を問わず対象にする
dotnet_naming_symbols.methods_properties_events.applicable_accessibilities = *
# private フィールドを _camelCase ルールの対象にする
dotnet_naming_symbols.private_fields.applicable_kinds = field
# private フィールドのみ対象にする（public/protected/internal は除外）
dotnet_naming_symbols.private_fields.applicable_accessibilities = private
# const フィールドを PascalCase ルールの対象にする
dotnet_naming_symbols.const_fields.applicable_kinds = field
# const フィールドはアクセス修飾子を問わず対象にする
dotnet_naming_symbols.const_fields.applicable_accessibilities = *
# const 修飾子を持つフィールドに限定する
dotnet_naming_symbols.const_fields.required_modifiers = const
# 引数を camelCase ルールの対象にする
dotnet_naming_symbols.parameters.applicable_kinds = parameter
# 引数はアクセス修飾子概念がないが、形式上すべて対象にする
dotnet_naming_symbols.parameters.applicable_accessibilities = *
# ローカル変数を camelCase ルールの対象にする
dotnet_naming_symbols.locals.applicable_kinds = local
# ローカル変数はアクセス修飾子概念がないが、形式上すべて対象にする
dotnet_naming_symbols.locals.applicable_accessibilities = *

# ---- 命名ルール定義 ----

# インターフェースは I + PascalCase にする（例: IEnemy）
dotnet_naming_rule.interfaces_must_start_with_i.symbols = interfaces
# インターフェース名に適用するスタイルは I + PascalCase
dotnet_naming_rule.interfaces_must_start_with_i.style = interface_prefix_i
# インターフェース命名違反は warning として通知する
dotnet_naming_rule.interfaces_must_start_with_i.severity = warning
# class/struct/enum は PascalCase にする
dotnet_naming_rule.types_pascal_case.symbols = types
# 型名に適用するスタイルは PascalCase
dotnet_naming_rule.types_pascal_case.style = pascal_case
# 型名命名違反は warning として通知する
dotnet_naming_rule.types_pascal_case.severity = warning
# メソッド/プロパティ/イベントは PascalCase にする
dotnet_naming_rule.methods_properties_events_pascal_case.symbols = methods_properties_events
# メソッド/プロパティ/イベントに適用するスタイルは PascalCase
dotnet_naming_rule.methods_properties_events_pascal_case.style = pascal_case
# メソッド/プロパティ/イベント命名違反は warning として通知する
dotnet_naming_rule.methods_properties_events_pascal_case.severity = warning
# private フィールドは _camelCase にする（例: _maxHp）
dotnet_naming_rule.private_fields_underscore_camel.symbols = private_fields
# private フィールドに適用するスタイルは _camelCase
dotnet_naming_rule.private_fields_underscore_camel.style = private_field_underscore
# private フィールド命名違反は warning として通知する
dotnet_naming_rule.private_fields_underscore_camel.severity = warning
# const フィールドは PascalCase にする（例: MaxPartyMemberCount）
dotnet_naming_rule.const_fields_pascal_case.symbols = const_fields
# const フィールドに適用するスタイルは PascalCase
dotnet_naming_rule.const_fields_pascal_case.style = pascal_case
# const フィールド命名違反は warning として通知する
dotnet_naming_rule.const_fields_pascal_case.severity = warning
# 引数は camelCase にする
dotnet_naming_rule.parameters_camel_case.symbols = parameters
# 引数に適用するスタイルは camelCase
dotnet_naming_rule.parameters_camel_case.style = camel_case
# 引数命名違反は warning として通知する
dotnet_naming_rule.parameters_camel_case.severity = warning
# ローカル変数は camelCase にする
dotnet_naming_rule.locals_camel_case.symbols = locals
# ローカル変数に適用するスタイルは camelCase
dotnet_naming_rule.locals_camel_case.style = camel_case
# ローカル変数命名違反は warning として通知する
dotnet_naming_rule.locals_camel_case.severity = warning