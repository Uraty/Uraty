# .editorconfig
# ============================================================
# 目的:
# - 文字コード/改行/インデントの揺れを潰す
# - C#(Unity) のスタイル/命名を「error中心」で強制する
# ============================================================

root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
trim_trailing_whitespace = false

[*.yml]
indent_style = space
indent_size = 2

[*.yaml]
indent_style = space
indent_size = 2

[*.json]
indent_style = space
indent_size = 2

# ------------------------------
# Unity の YAML 系アセット
# ------------------------------
[*.meta]
indent_style = space
indent_size = 2

[*.unity]
indent_style = space
indent_size = 2

[*.prefab]
indent_style = space
indent_size = 2

[*.asset]
indent_style = space
indent_size = 2

# ------------------------------
# C#（Unity 本体）
# ------------------------------
[*.cs]
indent_style = space
indent_size = 4
tab_width = 4

# ============================================================
# Analyzer/Style の基本方針（error中心）
# ============================================================

# Style/Naming は強めに
dotnet_analyzer_diagnostic.category-Style.severity = error
dotnet_analyzer_diagnostic.category-Naming.severity = error

# 未使用 using をエラー（溜めない）
dotnet_diagnostic.IDE0005.severity = error

# 命名規則に関係するIDEの一部（環境差で揺れが出るなら warning に落としてもいい）
dotnet_diagnostic.IDE1006.severity = error

# using 順序・配置
dotnet_sort_system_directives_first = true
dotnet_separate_import_directive_groups = true
csharp_using_directive_placement = outside_namespace

# アクセス修飾子は明示（曖昧さ排除）
# 既存の for_non_interface_members をさらに強くしたいなら always にする
dotnet_style_require_accessibility_modifiers = always:error

# this. は基本不要
dotnet_style_qualification_for_field = false:suggestion
dotnet_style_qualification_for_property = false:suggestion
dotnet_style_qualification_for_method = false:suggestion
dotnet_style_qualification_for_event = false:suggestion

# 組み込み型はキーワード表記
dotnet_style_predefined_type_for_locals_parameters_members = true:suggestion
dotnet_style_predefined_type_for_member_access = true:suggestion

# if等の波括弧は必須（事故防止）
csharp_prefer_braces = true:error

# 開き波括弧の位置を統一
csharp_new_line_before_open_brace = all
csharp_new_line_before_else = true
csharp_new_line_before_catch = true
csharp_new_line_before_finally = true

# 初期化子・匿名型の改行
csharp_new_line_before_members_in_object_initializers = true
csharp_new_line_before_members_in_anonymous_types = true

# switch
csharp_indent_case_contents = true
csharp_indent_switch_labels = true
csharp_indent_labels = one_less_than_current

# 単一行ブロック/文の温存を禁止（表記揺れを減らす）
csharp_preserve_single_line_blocks = false
csharp_preserve_single_line_statements = false

# var 方針（あなたの元設定を踏襲）
# - 組み込み型は明示を優先
# - 右辺から明白なら var は許容
csharp_style_var_for_built_in_types = false:suggestion
csharp_style_var_when_type_is_apparent = true:suggestion
csharp_style_var_elsewhere = false:suggestion

# expression-bodied は読みやすさ優先で抑制
csharp_style_expression_bodied_properties = when_on_single_line:suggestion
csharp_style_expression_bodied_accessors = false:suggestion

# null系（推奨）
dotnet_style_null_propagation = true:suggestion
dotnet_style_coalesce_expression = true:suggestion
dotnet_style_prefer_is_null_check_over_reference_equality_method = true:suggestion

# auto property / initializer 推奨
dotnet_style_prefer_auto_properties = true:suggestion
dotnet_style_collection_initializer = true:suggestion
dotnet_style_object_initializer = true:suggestion

# ============================================================
# C# 命名規則（error中心）
# ============================================================

# ---- 命名スタイル定義 ----
dotnet_naming_style.pascal_case.capitalization = pascal_case
dotnet_naming_style.camel_case.capitalization = camel_case

dotnet_naming_style.interface_prefix_i.required_prefix = I
dotnet_naming_style.interface_prefix_i.capitalization = pascal_case

dotnet_naming_style.private_field_underscore.required_prefix = _
dotnet_naming_style.private_field_underscore.capitalization = camel_case

# ---- 対象シンボル定義 ----
dotnet_naming_symbols.interfaces.applicable_kinds = interface
dotnet_naming_symbols.interfaces.applicable_accessibilities = *

dotnet_naming_symbols.types.applicable_kinds = class, struct, enum
dotnet_naming_symbols.types.applicable_accessibilities = *

dotnet_naming_symbols.methods_properties_events.applicable_kinds = method, property, event
dotnet_naming_symbols.methods_properties_events.applicable_accessibilities = *

dotnet_naming_symbols.private_fields.applicable_kinds = field
dotnet_naming_symbols.private_fields.applicable_accessibilities = private

dotnet_naming_symbols.const_fields.applicable_kinds = field
dotnet_naming_symbols.const_fields.applicable_accessibilities = *
dotnet_naming_symbols.const_fields.required_modifiers = const

dotnet_naming_symbols.parameters.applicable_kinds = parameter
dotnet_naming_symbols.parameters.applicable_accessibilities = *

dotnet_naming_symbols.locals.applicable_kinds = local
dotnet_naming_symbols.locals.applicable_accessibilities = *

# ---- 命名ルール定義（全部 error） ----
dotnet_naming_rule.interfaces_must_start_with_i.symbols = interfaces
dotnet_naming_rule.interfaces_must_start_with_i.style = interface_prefix_i
dotnet_naming_rule.interfaces_must_start_with_i.severity = error

dotnet_naming_rule.types_pascal_case.symbols = types
dotnet_naming_rule.types_pascal_case.style = pascal_case
dotnet_naming_rule.types_pascal_case.severity = error

dotnet_naming_rule.methods_properties_events_pascal_case.symbols = methods_properties_events
dotnet_naming_rule.methods_properties_events_pascal_case.style = pascal_case
dotnet_naming_rule.methods_properties_events_pascal_case.severity = error

dotnet_naming_rule.private_fields_underscore_camel.symbols = private_fields
dotnet_naming_rule.private_fields_underscore_camel.style = private_field_underscore
dotnet_naming_rule.private_fields_underscore_camel.severity = error

dotnet_naming_rule.const_fields_pascal_case.symbols = const_fields
dotnet_naming_rule.const_fields_pascal_case.style = pascal_case
dotnet_naming_rule.const_fields_pascal_case.severity = error

dotnet_naming_rule.parameters_camel_case.symbols = parameters
dotnet_naming_rule.parameters_camel_case.style = camel_case
dotnet_naming_rule.parameters_camel_case.severity = error

dotnet_naming_rule.locals_camel_case.symbols = locals
dotnet_naming_rule.locals_camel_case.style = camel_case
dotnet_naming_rule.locals_camel_case.severity = error